# On-Premises Kubernetes Simulation Config Template
# Copy this file to secrets/.env and customize

# Cluster Configuration
K8S_CLUSTER_NAME=onprem-k8s
INGRESS_DOMAIN=app.local

# MetalLB IP Range (must match the k8s-net Docker network subnet)
# If using subnet 172.20.0.0/16, MetalLB can allocate from .200 to .250
METAL_IP_RANGE=172.20.0.200-172.20.0.250
DOCKER_SUBNET=172.20.0.0/16
DOCKER_GATEWAY=172.20.0.1

# Database Configuration (PostgreSQL)
DB_USER=
DB_PASSWORD=
DB_NAME=app_db

# HashiCorp Vault Integration (Optional)
VAULT_ADDR=
VAULT_TOKEN=

# Directory for logs
LOG_DIR=./logs
GIT_REPO_URL=

# Backup Configuration (Velero)
GCS_BACKUP_BUCKET=

# Set to 1 for lightweight laptops, or 3 for High Availability Quorum
CONTROL_PLANE_COUNT=1
